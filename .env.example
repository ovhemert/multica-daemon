MULTICA_APP_URL=http://localhost:3000
MULTICA_SERVER_URL=http://localhost:8080
# Set your Multica token here (format: mul_…)
MULTICA_TOKEN=
# Optional: token used by the daemon for private GitHub repository clones.
# GITHUB_TOKEN=

# Plain docker users can set a stable daemon ID.
# Docker Compose assigns per-service IDs in docker-compose.yml.
# MULTICA_DAEMON_ID=daemon-dev
